{
  "version": 2,
  "routes": [
    {
      "src": "/sw.js",
      "headers": { "Cache-Control": "no-cache", "Service-Worker-Allowed": "/" },
      "dest": "/sw.js"
    },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/icon-(.*)", "dest": "/icon-$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
